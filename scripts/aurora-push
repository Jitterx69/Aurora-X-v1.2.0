#!/usr/bin/env python3
import sys
import json
import requests
import argparse

def main():
    parser = argparse.ArgumentParser(description="Push changes for review to the Aurora-X platform.")
    parser.add_argument("--message", "-m", required=True, help="Description of the changes.")
    parser.add_argument("--file", "-f", help="Path to a file containing the proposed changes (JSON).")
    parser.add_argument("--api-url", default="http://localhost:8000", help="Root URL of the Aurora-X API.")

    args = parser.parse_args()

    changes = {"description": args.message}
    if args.file:
        try:
            with open(args.file, 'r') as f:
                content = f.read()
                try:
                    changes["payload"] = json.loads(content)
                except json.JSONDecodeError:
                    changes["payload"] = content
        except Exception as e:
            print(f"Error reading file: {e}")
            sys.exit(1)

    try:
        response = requests.post(f"{args.api_url}/api/security/reviews", json=changes)
        response.raise_for_status()
        result = response.json()
        if result.get("status") == "SUCCESS":
            print(f"[OK] Successfully pushed for review. Ticket ID: {result.get('ticket_id')}")
        else:
            print(f"[FAIL] Failed to push: {result.get('message', 'Unknown error')}")
    except Exception as e:
        print(f"[ERROR] Connection error: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
